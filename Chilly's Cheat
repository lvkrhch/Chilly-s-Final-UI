end

local function getNextKey(currentKey)
    local currentIndex = table.find(keyChoices, currentKey) or 1
    local nextIndex = currentIndex + 1

    if nextIndex > #keyChoices then
        nextIndex = 1
    end

    return keyChoices[nextIndex]
end

local function destroyEsp(player)
    local highlight = espHighlights[player]
    if highlight then
        highlight:Destroy()
        espHighlights[player] = nil
    end

    local box = espBoxes[player]
    if box then
        box:Destroy()
        espBoxes[player] = nil
    end

    local billboard = espBillboards[player]
    if billboard then
        billboard:Destroy()
        espBillboards[player] = nil
    end
end

local function shouldShowEsp(player)
    if player == localPlayer then
        return false
    end

    if not settings.espCharm and not settings.espBox and not settings.espHealth then
        return false
    end

    return isAlive(player)
end

local function updateEspForPlayer(player)
    if not shouldShowEsp(player) then
        destroyEsp(player)
        return
    end

    local character = getCharacter(player)
    local humanoid = getHumanoid(character)
    local root = getRootPart(character)

    if not character or not humanoid or not root then
        destroyEsp(player)
        return
    end

    local isFriendly = isTeamMatch() and hasMatchingTeam(player)
    local mainColor = isFriendly and Color3.fromRGB(55, 145, 255) or Color3.fromRGB(255, 75, 60)
    local accentColor = isFriendly and Color3.fromRGB(175, 220, 255) or Color3.fromRGB(255, 220, 120)

    if settings.espCharm then
        local highlight = espHighlights[player]

        if not highlight or highlight.Parent ~= character then
            if highlight then
                highlight:Destroy()
            end

            highlight = Instance.new("Highlight")
            highlight.Name = "ChillyEspCharm"
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.FillTransparency = 0.6
            highlight.OutlineTransparency = 0.15
            highlight.Adornee = character
            highlight.Parent = character

            espHighlights[player] = highlight
        end

        highlight.FillColor = mainColor
        highlight.OutlineColor = accentColor
    elseif espHighlights[player] then
        espHighlights[player]:Destroy()
        espHighlights[player] = nil
    end

    if settings.espBox then
        local box = espBoxes[player]

        if not box or box.Parent ~= root then
            if box then
                box:Destroy()
            end

            box = Instance.new("BoxHandleAdornment")
            box.Name = "ChillyEspBox"
            box.AlwaysOnTop = true
            box.Adornee = root
            box.ZIndex = 4
            box.Transparency = 0.45
            box.Size = Vector3.new(4, 6, 2.5)
            box.Parent = root

            espBoxes[player] = box
        end

        box.Color3 = mainColor
    elseif espBoxes[player] then
        espBoxes[player]:Destroy()
        espBoxes[player] = nil
    end

    if settings.espHealth then
        local billboard = espBillboards[player]

        if not billboard or billboard.Parent ~= root then
            if billboard then
                billboard:Destroy()
            end

            billboard = Instance.new("BillboardGui")
            billboard.Name = "ChillyEspHealth"
            billboard.AlwaysOnTop = true
            billboard.Size = UDim2.fromOffset(86, 34)
            billboard.StudsOffset = Vector3.new(0, 3.6, 0)
            billboard.Adornee = root
            billboard.Parent = root

            local label = Instance.new("TextLabel")
            label.Name = "NameLabel"
            label.Size = UDim2.new(1, 0, 0, 16)
            label.BackgroundTransparency = 1
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.TextStrokeTransparency = 0.35
            label.Font = Enum.Font.GothamBold
            label.TextSize = 11
            label.Parent = billboard

            local barBack = Instance.new("Frame")
            barBack.Name = "BarBack"
            barBack.Size = UDim2.new(1, -12, 0, 6)
            barBack.Position = UDim2.fromOffset(6, 21)
            barBack.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            barBack.BorderSizePixel = 0
            barBack.Parent = billboard

            local bar = Instance.new("Frame")
            bar.Name = "Bar"
            bar.Size = UDim2.new(1, 0, 1, 0)
            bar.BackgroundColor3 = Color3.fromRGB(70, 215, 105)
            bar.BorderSizePixel = 0
            bar.Parent = barBack

            espBillboards[player] = billboard
        end

        local label = billboard:FindFirstChild("NameLabel")
        local barBack = billboard:FindFirstChild("BarBack")
        local bar = barBack and barBack:FindFirstChild("Bar")
        local ratio = humanoid.MaxHealth > 0 and math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1) or 0

        if label then
            label.Text = player.Name .. " " .. tostring(math.floor(humanoid.Health))
        end

        if bar then
            bar.Size = UDim2.new(ratio, 0, 1, 0)
            bar.BackgroundColor3 = Color3.fromRGB(220 - 150 * ratio, 65 + 150 * ratio, 70)
        end
    elseif espBillboards[player] then
        espBillboards[player]:Destroy()
        espBillboards[player] = nil
    end
end

local function refreshEsp()
    for _, player in ipairs(Players:GetPlayers()) do
        updateEspForPlayer(player)
    end
end

local function destroyHitbox(player)
    local part = hitboxParts[player]

    if part then
        part:Destroy()
        hitboxParts[player] = nil
    end
end

local function isValidHitboxTarget(player)
    if player == localPlayer then
        return false
    end

    if not isAlive(player) then
        return false
    end

    if settings.hitboxTargetMode == "Enemies" or settings.hitboxTargetMode == "Target" then
        return not isSameTeam(player)
    end

    return true
end

local function getBestHitboxTarget()
    local bestPlayer = nil
    local bestDistance = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if isValidHitboxTarget(player) then
            local root = getRootPart(getCharacter(player))

            if root then
                local distance = getWorldDistanceFromLocalPlayer(root.Position)

                if distance < bestDistance then
                    bestDistance = distance
                    bestPlayer = player
                end
            end
        end
    end

    return bestPlayer
end

local function shouldExpandHitboxForPlayer(player)
    if not settings.hitboxExpander or not isValidHitboxTarget(player) then
        return false
    end

    if settings.hitboxTargetMode == "Target" then
        return player == (currentTarget or getBestHitboxTarget())
    end

    if settings.hitboxTargetMode == "Enemies" then
        return true
    end

    return true
end

local function getHitboxSize()
    if settings.hitboxShape == "Box" then
        return Vector3.new(settings.hitboxSize * 0.75, settings.hitboxSize, settings.hitboxSize * 0.5)
    end

    return Vector3.new(settings.hitboxSize, settings.hitboxSize, settings.hitboxSize)
end

local function getHitboxColor(player)
    if player == currentTarget then
        return Color3.fromRGB(255, 215, 80)
    end

    if isSameTeam(player) then
        return Color3.fromRGB(55, 145, 255)
    end

    return Color3.fromRGB(255, 80, 80)
end

local function updateHitboxForPlayer(player)
    if not shouldExpandHitboxForPlayer(player) then
        destroyHitbox(player)
        return
    end

    local character = getCharacter(player)
    local root = getRootPart(character)

    if not character or not root then
        destroyHitbox(player)
        return
    end

    local hitbox = hitboxParts[player]
    if not hitbox or hitbox.Parent ~= character then
        destroyHitbox(player)

        hitbox = Instance.new("Part")
        hitbox.Name = "ChillyHitboxExpander"
        hitbox.Material = Enum.Material.ForceField
        hitbox.Transparency = settings.hitboxTransparency
        hitbox.CanCollide = false
        hitbox.CanTouch = false
        hitbox.CanQuery = true
        hitbox.Massless = true
        hitbox.Anchored = false
        hitbox.CFrame = root.CFrame
        hitbox:SetAttribute("ChillyHitboxIgnoresWallCheck", true)
        hitbox:SetAttribute("ChillyHitboxOwnerUserId", player.UserId)
        hitbox:SetAttribute("ChillyHitboxTargetMode", settings.hitboxTargetMode)
        hitbox.Parent = character

        local weld = Instance.new("WeldConstraint")
        weld.Part0 = hitbox
        weld.Part1 = root
        weld.Parent = hitbox

        hitboxParts[player] = hitbox
    end

    hitbox.Shape = settings.hitboxShape == "Ball" and Enum.PartType.Ball or Enum.PartType.Block
    hitbox.Size = getHitboxSize()
    hitbox.Color = getHitboxColor(player)
    hitbox.Transparency = settings.hitboxTransparency
    hitbox:SetAttribute("ChillyHitboxTargetMode", settings.hitboxTargetMode)
    hitbox.CFrame = root.CFrame
end

local function refreshHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        updateHitboxForPlayer(player)
    end
end

local function clearHitboxes()
    for player in pairs(hitboxParts) do
        destroyHitbox(player)
    end
end

local function applyNoclip()
    local character = getCharacter(localPlayer)
    if not character then
        return
    end

    if settings.noclipEnabled then
        for _, descendant in ipairs(character:GetDescendants()) do
            if descendant:IsA("BasePart") then
                if originalCollisions[descendant] == nil then
                    originalCollisions[descendant] = descendant.CanCollide
                end

                descendant.CanCollide = false
            end
        end
        return
    end

    for part, canCollide in pairs(originalCollisions) do
        if part and part.Parent then
            part.CanCollide = canCollide
        end
        originalCollisions[part] = nil
    end
end

local function applyFly(deltaTime)
    local character = getCharacter(localPlayer)
    local humanoid = getHumanoid(character)
    local root = getRootPart(character)

    if not character or not humanoid or not root then
        return
    end

    if not settings.flyEnabled then
        humanoid.PlatformStand = false
        return
    end

    camera = workspace.CurrentCamera
    if not camera then
        return
    end

    local moveDirection = Vector3.new(0, 0, 0)

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - camera.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + Vector3.new(0, 1, 0)
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        moveDirection = moveDirection - Vector3.new(0, 1, 0)
    end

    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit
    end

    humanoid.PlatformStand = true
    local targetVelocity = moveDirection * settings.flySpeed
    local alpha = math.clamp((deltaTime or 1 / 60) * 12, 0.05, 0.6)
    root.AssemblyLinearVelocity = root.AssemblyLinearVelocity:Lerp(targetVelocity, alpha)
    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

local function teleportToPlayer(player)
    if not player or player == localPlayer then
        return
    end

    local localRoot = getLocalRootPart()
    local targetRoot = getRootPart(getCharacter(player))

    if not localRoot or not targetRoot then
        return
    end

    localRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 4)
    localRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end

local function getTeleportPlayers()
    local list = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer and getCharacter(player) then
            table.insert(list, player)
        end
    end

    table.sort(list, function(a, b)
        return a.Name:lower() < b.Name:lower()
    end)

    return list
end

local function ensureSelectedTeleportPlayer()
    local list = getTeleportPlayers()

    if #list == 0 then
        selectedTeleportPlayer = nil
        return nil
    end

    for _, player in ipairs(list) do
        if player == selectedTeleportPlayer then
            return selectedTeleportPlayer
        end
    end

    selectedTeleportPlayer = list[1]
    return selectedTeleportPlayer
end

local function cycleTeleportPlayer()
    local list = getTeleportPlayers()

    if #list == 0 then
        selectedTeleportPlayer = nil
        return
    end

    local currentIndex = nil
    for index, player in ipairs(list) do
        if player == selectedTeleportPlayer then
            currentIndex = index
            break
        end
    end

    local nextIndex = currentIndex and currentIndex + 1 or 1
    if nextIndex > #list then
        nextIndex = 1
    end

    selectedTeleportPlayer = list[nextIndex]
end

local function destroyTool()
    if isDestroyed then
        return
    end

    isDestroyed = true
    settings.enabled = false
    settings.espCharm = false
    settings.espBox = false
    settings.espHealth = false
    settings.hitboxExpander = false
    settings.flyEnabled = false
    settings.noclipEnabled = false
    settings.infiniteJumpEnabled = false
    refreshUi = nil

    RunService:UnbindFromRenderStep(renderStepName)
    setCurrentTarget(nil)
    clearHitboxes()

    for _, player in ipairs(Players:GetPlayers()) do
        destroyEsp(player)
        destroyHitbox(player)
    end

    applyNoclip()

    local humanoid = getLocalHumanoid()
    if humanoid then
        humanoid.PlatformStand = false
    end

    for _, connection in ipairs(connections) do
        if connection then
            connection:Disconnect()
        end
    end

    table.clear(connections)

    for player, connection in pairs(playerCharacterConnections) do
        if connection then
            connection:Disconnect()
        end
        playerCharacterConnections[player] = nil
    end

    if Chillys then
        Chillys:Destroy()
        Chillys = nil
    end
end

